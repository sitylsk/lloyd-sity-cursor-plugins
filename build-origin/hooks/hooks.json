{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/session-start.mjs\"",
        "timeout": 8
      }
    ],
    "afterFileEdit": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/after-edit.mjs\"",
        "timeout": 8
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/after-edit.mjs\"",
        "timeout": 8
      }
    ],
    "stop": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/stop.mjs\"",
        "timeout": 10
      }
    ]
  }
}
